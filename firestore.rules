rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    // ---- Owned collections (auto-generated docIds, ownerId field) ----

    match /series/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /lessons/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /sections/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /study_briefs/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /voice_corpus/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /sermon_annotations/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    // ---- Singleton profiles (docId == userId) ----

    match /teacher_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /class_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /doctrinal_positions/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
